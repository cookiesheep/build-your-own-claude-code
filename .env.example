# Your Anthropic API Key (required for live testing only, not needed for unit tests)
ANTHROPIC_API_KEY=your-api-key-here

# Optional: custom endpoint
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# Optional: model override
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# -----------------------------------------------------------------------------
# BYOCC platform / public demo settings
# -----------------------------------------------------------------------------
# Required before exposing the backend through Cloudflare Tunnel.
# Generate a real value locally, for example:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
BYOCC_AUTH_SECRET=replace-with-a-random-32-byte-secret
SERVER_SESSION_SECRET=replace-with-a-random-32-byte-secret
BYOCC_COOKIE_SECURE=false

# Keep true for backward-compatible local API regression. Set false for public demos
# once provisioned username/password accounts are ready.
BYOCC_ANONYMOUS_AUTH_ENABLED=true
BYOCC_ANONYMOUS_TOKEN_TTL_SECONDS=86400

# Backend server binding.
# Local development: HOST=127.0.0.1
# Cloudflare Tunnel on the same machine can still target http://127.0.0.1:3001.
# Only use HOST=0.0.0.0 if you deliberately need LAN access and understand the risk.
HOST=127.0.0.1
PORT=3001

# Browser origins allowed to call the backend.
# Local development example:
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Public demo example:
# CORS_ORIGINS=https://byocc-demo.example.com

# Frontend API base URL.
# Local development:
NEXT_PUBLIC_API_URL=http://127.0.0.1:3001
# Public demo example:
# NEXT_PUBLIC_API_URL=https://byocc-api.example.com

# Container lifecycle.
BYOCC_CONTAINER_CLEANUP_ENABLED=true
BYOCC_CONTAINER_TTL_MINUTES=120
BYOCC_CONTAINER_CLEANUP_INTERVAL_MINUTES=10
BYOCC_CONTAINER_CLEANUP_RUN_ON_START=false

# Terminal websocket capability token TTL.
BYOCC_TERMINAL_TOKEN_TTL_SECONDS=300
