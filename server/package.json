{
  "name": "byocc-server",
  "version": "0.1.0",
  "description": "Build Your Own Claude Code - Backend API Server",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node --loader ts-node/esm dist/index.js",
    "build": "tsc",
    "test": "vitest run",
    "cleanup:containers": "tsx src/scripts/cleanup-containers.ts",
    "auth:create-user": "tsx src/scripts/create-user.ts",
    "e2e:regression": "tsx src/scripts/e2e-regression.ts",
    "e2e:regression:full": "tsx src/scripts/e2e-regression.ts --full-docker"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^11.0.0",
    "cors": "^2.8.0",
    "dockerode": "^4.0.0",
    "express": "^4.18.0",
    "http-proxy": "^1.18.0",
    "jsonwebtoken": "^9.0.3",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.0",
    "@types/cors": "^2.8.0",
    "@types/dockerode": "^3.3.0",
    "@types/express": "^4.17.0",
    "@types/http-proxy": "^1.17.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.0.0",
    "@types/uuid": "^9.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
