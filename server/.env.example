# Requires Node.js >= 20.6.0 for `node --env-file=.env dist/index.js`

# === 认证 ===
BYOCC_AUTH_SECRET=
SERVER_SESSION_SECRET=
ENCRYPTION_KEY=

# === 网络与安全 ===
HOST=127.0.0.1
PORT=3001
CORS_ORIGINS=https://byocc.cc
BYOCC_COOKIE_SECURE=true

# === 认证模式 ===
BYOCC_ANONYMOUS_AUTH_ENABLED=false
BYOCC_ANONYMOUS_TOKEN_TTL_SECONDS=86400

# === API Key ===
DEFAULT_API_KEY=
DEFAULT_API_BASE_URL=https://api.anthropic.com

# === 容器 ===
BYOCC_CONTAINER_CLEANUP_ENABLED=true
BYOCC_CONTAINER_TTL_MINUTES=120
BYOCC_CONTAINER_CLEANUP_INTERVAL_MINUTES=10
BYOCC_CONTAINER_CLEANUP_RUN_ON_START=false
BYOCC_TERMINAL_TOKEN_TTL_SECONDS=300

# === LLM Proxy ===
BYOCC_LLM_PROXY_URL=
BYOCC_DEFAULT_KEY_DAILY_LIMIT=500
BYOCC_DEFAULT_KEY_SESSION_LIMIT=100
BYOCC_LLM_PROXY_TIMEOUT_MS=120000
BYOCC_ALLOWED_LLM_BASE_URLS=
