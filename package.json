{
  "name": "build-your-own-claude-code",
  "version": "0.1.0",
  "description": "A task-driven, learn-by-building tutorial for creating a coding agent harness from scratch",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:task": "vitest run --reporter=verbose",
    "build": "tsc --noEmit",
    "start": "node --loader ts-node/esm src/main.ts",
    "lint": "eslint . --ext .ts,.tsx"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "tsx": "^4.0.0",
    "ts-node": "^10.9.0",
    "@types/node": "^20.0.0"
  },
  "keywords": [
    "agent",
    "coding-agent",
    "harness",
    "tutorial",
    "learn-by-building",
    "claude",
    "llm",
    "ai"
  ],
  "license": "MIT"
}
